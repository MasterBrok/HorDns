<Page
    x:Class="Application.Pages.Dashboard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Application.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="clr-namespace:Application.UserControls"
    Title="Dashboard"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid Grid.Column="1">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.RowSpan="2">

            <Grid>
                <Image
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Source="/Resources/Assets/bg.png"
                    Stretch="Uniform" />

            </Grid>

        </Border>
        <StackPanel
            Margin="40,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Orientation="Horizontal">
            <Image
                Width="140"
                Height="140"
                Source="/Resources/Assets/ready.png"
                Stretch="UniformToFill" />
            <TextBlock
                Margin="30,0"
                VerticalAlignment="Center"
                FontFamily="{StaticResource Main}"
                FontSize="25"
                FontWeight="Bold"
                Foreground="#402258"
                Text="Hey!Ready To Connect?" />
        </StackPanel>

        <!--<Button
            Height="120"
            Width="35"
            Margin="5"
            FontSize="10"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Grid.Row="1"
            Foreground="White"
            Content="Ping"
            Style="{StaticResource ShiningButton}"
            />-->
        <ScrollViewer
            Grid.Row="1"
            HorizontalAlignment="Left"
            HorizontalScrollBarVisibility="Disabled"
            Style="{DynamicResource ScrollViewerStyle}"
            VerticalScrollBarVisibility="Auto">
            <ScrollViewer.Resources>
                <Style TargetType="uc:DnsCard">
                    <Setter Property="Width" Value="330" />
                    <Setter Property="Height" Value="160" />
                    <Setter Property="Margin" Value="5,4" />
                </Style>
            </ScrollViewer.Resources>
            <WrapPanel x:Name="wpDns" IsEnabled="False">
                <WrapPanel.Style>
                    <Style TargetType="WrapPanel">
                        <Setter Property="RenderTransformOrigin" Value="0.5 0.5" />
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <RotateTransform Angle="0" />
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value=".5" />
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <BlurEffect KernelType="Gaussian" Radius="2" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </WrapPanel.Style>
            </WrapPanel>
        </ScrollViewer>
    </Grid>
</Page>
