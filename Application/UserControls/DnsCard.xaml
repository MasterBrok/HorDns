<UserControl
    x:Class="Application.UserControls.DnsCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:con="clr-namespace:Application.Conventers"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Application.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="160"
    d:DesignWidth="340"
    mc:Ignorable="d">
    <UserControl.Resources>
        <con:ColorHexConventer x:Key="convertToColor" />
    </UserControl.Resources>

    <Border
        x:Name="brdMain"
        BorderBrush="{Binding Resource.BorderColor, Converter={StaticResource convertToColor}}"
        BorderThickness="1"
        CornerRadius="20">
        <Border.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation
                            Storyboard.TargetProperty="Opacity"
                            From="0"
                            To="1"
                            Duration="00:00:01" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>
        <Border.Resources>
            <!--<Style
                x:Key="Animate"
                TargetType="Border">
                <Setter Property="Opacity" Value="1"/>
                <Style.Triggers>

                </Style.Triggers>
            </Style>-->
            <Style TargetType="Button">
                <Setter Property="Foreground" Value="{StaticResource SecondTextColor}" />
                <Setter Property="FontSize" Value="19" />
                <Setter Property="FontFamily" Value="{StaticResource Main}" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="Width" Value="120" />
                <Setter Property="Height" Value="40" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Background" Value="{StaticResource Btn.Bg.Connect}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border
                                x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20">
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="10"
                                        Opacity="0.9"
                                        ShadowDepth="5"
                                        Color="{Binding Background.Color, RelativeSource={RelativeSource TemplatedParent}, IsAsync=True}" />
                                </Border.Effect>
                                <ContentPresenter
                                    Margin="0"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="Tag" Value="true">
                                    <Setter TargetName="border" Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect
                                                BlurRadius="30"
                                                Opacity="0.5"
                                                ShadowDepth="10"
                                                Color="{Binding Background.Color, RelativeSource={RelativeSource TemplatedParent}, IsAsync=True}" />
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Background" Value="#9083F0" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect
                                                BlurRadius="25"
                                                Opacity="0.9"
                                                ShadowDepth="10"
                                                Color="{Binding Background.Color, RelativeSource={RelativeSource TemplatedParent}, IsAsync=True}" />
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect
                                                BlurRadius="25"
                                                Opacity="0.9"
                                                ShadowDepth="10"
                                                Color="{Binding Foreground.Color, RelativeSource={RelativeSource TemplatedParent}, IsAsync=True}" />
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>

            </Style>
        </Border.Resources>

        <!--<Border.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0" >
                <GradientStop Color="#F4BEF5" Offset="0.523"/>
                <GradientStop Color="#E0D4F9" Offset="0.893"/>

                <GradientStop Color="#F8D4F8" Offset="0.744"/>
            </LinearGradientBrush>
        </Border.Background>-->
        <Grid>

            <Border
                x:Name="brdAnimate"
                Grid.ColumnSpan="2"
                Background="{Binding Resource.Colors, Converter={StaticResource convertToColor}}"
                CornerRadius="{Binding ElementName=brdMain, Path=CornerRadius}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}, Path=IsMouseOver}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Opacity" Value=".8" />
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <BlurEffect
                                            KernelType="Gaussian"
                                            Radius="30"
                                            RenderingBias="Quality" />
                                    </Setter.Value>
                                </Setter>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>
            <Grid Margin="20,0" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Margin="10,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center">
                    <Image
                        Height="70"
                        Margin="0,5"
                        HorizontalAlignment="Left"
                        Source="{Binding Resource.Character, UpdateSourceTrigger=PropertyChanged, NotifyOnSourceUpdated=True}" />
                    <ScrollViewer
                        x:Name="svTitle"
                        HorizontalScrollBarVisibility="Hidden"
                        VerticalScrollBarVisibility="Hidden">
                        <TextBlock
                            x:Name="tbTitle"
                            HorizontalAlignment="Center"
                            FontFamily="{StaticResource Main}"
                            FontSize="17"
                            FontWeight="Bold"
                            Foreground="{StaticResource CardTextColor}"
                            RenderTransformOrigin="0.5 0.5"
                            Text="{Binding Dns.Title}">
                            <TextBlock.RenderTransform>
                                <TranslateTransform X="0" />
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </ScrollViewer>
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Main}"
                        FontSize="15"
                        FontWeight="Regular"
                        Foreground="{StaticResource CardTextColor}"
                        Text="{Binding Dns.Dns.Preferred}" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Main}"
                        FontSize="10"
                        FontWeight="Regular"
                        Foreground="{StaticResource CardTextColor}"
                        Text="{Binding Dns.Dns.Alternate}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5">
                    <Image
                        Height="70"
                        Margin="0,5"
                        HorizontalAlignment="Center"
                        Source="{Binding Resource.Symbol}" />
                    <!--<TextBlock
                            Foreground="{StaticResource Btn.Bg.Connect}"
                           FontSize="10"
                           FontWeight="Regular"
                           FontFamily="{StaticResource Main}"
                           HorizontalAlignment="Center"
                    >
                       <Run>Ping</Run>
                       <Run x:Name="rnPing" Text="{Binding Dns.Ping}" Foreground="WhiteSmoke" ></Run>
                       <Run>ms</Run>
                    </TextBlock>-->
                    <Button
                        x:Name="btnConnect"
                        Click="Connect_Click"
                        Content="Connect" />

                </StackPanel>

            </Grid>
        </Grid>
    </Border>
</UserControl>
