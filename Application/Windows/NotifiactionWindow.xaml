<Window
    x:Class="Application.Windows.NotifiactionWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Application.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    Title="NotifiactionWindow"
    Width="400"
    Height="200"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None"
    mc:Ignorable="d">

    <Border CornerRadius="20">
        <Border.Background>
            <LinearGradientBrush MappingMode="RelativeToBoundingBox" SpreadMethod="Repeat" StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Offset="0.6" Color="{DynamicResource Notification.Bg.GR.1}" />
                <GradientStop Offset="1" Color="{DynamicResource Notification.Bg.GR.2}" />
            </LinearGradientBrush>
        </Border.Background>
        <Grid Margin="10">
            <Image
                Width="160"
                HorizontalAlignment="Right"
                Source="{Binding Image, NotifyOnTargetUpdated=True, NotifyOnSourceUpdated=True, UpdateSourceTrigger=PropertyChanged}"
                Stretch="Fill">
                <Image.Effect>
                    <DropShadowEffect
                        BlurRadius="50"
                        Direction="233"
                        ShadowDepth="2"
                        Color="{DynamicResource Notification.Bg.GR.1}" />
                </Image.Effect>
            </Image>
            <TextBlock
                Width="240"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                FontFamily="{StaticResource Main}"
                FontSize="19"
                Foreground="{StaticResource PrimaryTextColor}"
                Text="{Binding Message.Text, NotifyOnTargetUpdated=True, NotifyOnSourceUpdated=True, UpdateSourceTrigger=PropertyChanged}"
                TextWrapping="Wrap">
                <TextBlock.Effect>
                    <DropShadowEffect
                        BlurRadius="10"
                        ShadowDepth="4"
                        Color="{DynamicResource Notification.Bg.GR.1}" />
                </TextBlock.Effect>
            </TextBlock>
        </Grid>
    </Border>
</Window>
