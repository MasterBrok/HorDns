<Window x:Class="Application.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Application"
        xmlns:cc="clr-namespace:Application.Controls"
        xmlns:uc="clr-namespace:Application.UserControls"
        mc:Ignorable="d"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanMinimize"
        Width="1320"
        WindowStartupLocation="CenterScreen"
        Height="700"
        Loaded="Window_Loaded"
        xmlns:tb="clr-namespace:H.NotifyIcon;assembly=H.NotifyIcon.Wpf"
        Title="Hor Dns"
        WindowChrome.IsHitTestVisibleInChrome="False"
        WindowChrome.WindowChrome="{x:Null}"
        ShowInTaskbar="True"
        Topmost="False"
        >

    <Border
        CornerRadius="40">
        <Border.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0" MappingMode="RelativeToBoundingBox" SpreadMethod="Repeat">
                <GradientStop Color="{DynamicResource Main.Bg.GR.1}" Offset="0.6"/>
                <GradientStop Color="{DynamicResource Main.Bg.GR.2}" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Grid>
            <Grid.RowDefinitions>
                <!--StatusBar-->
                <RowDefinition Height="80"/>
                <!--Page-->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <tb:TaskbarIcon
                    x:Name="MyNotifyIcon"
                    ToolTipText="hello world"
                    TrayContextMenuOpen="MyNotifyIcon_TrayContextMenuOpen"
                    PreviewTrayContextMenuOpen="MyNotifyIcon_PreviewTrayContextMenuOpen"
                        IconSource="/Icons/trayfavorite.ico"    
                        >

                <tb:TaskbarIcon.ContextMenu>
                    <ContextMenu>
                        <ContextMenu.Style>
                            <Style TargetType="ContextMenu">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0" MappingMode="RelativeToBoundingBox" SpreadMethod="Repeat">
                                            <GradientStop Color="{DynamicResource Main.Bg.GR.1}" Offset="0.6"/>
                                            <GradientStop Color="{DynamicResource Main.Bg.GR.2}" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ContextMenu.Style>
                        <MenuItem
                   Click="Open_MenuItem_Click"
                     Header="Open"
                      />
                        <Separator />

                        <MenuItem
                            Click="Exit_MenuItem_Click"
                            
                             Header="Exit"
                                />



                       

                    </ContextMenu>
                </tb:TaskbarIcon.ContextMenu>

            </tb:TaskbarIcon>


            <DockPanel
                MouseLeftButtonDown="DockPanel_MouseLeftButtonDown"
                Background="Transparent"
                      Margin="20 0"
                      >
                <DockPanel.Resources>
                    <Style TargetType="{x:Type cc:ButtonIcon}">
                        <Setter Property="Width" Value="60"/>
                        <Setter Property="Height" Value="60"/>
                        <Setter Property="Margin" Value="20 0"/>
                    </Style>
                </DockPanel.Resources>
                <StackPanel 
                      Width="Auto"
                      Orientation="Horizontal"
                      DockPanel.Dock="Right">
                    <cc:ButtonIcon
                        Click="Exit_Click"
                            Margin="0"
                            ButtonTemplate="OnlyIcon"
                            Icon="{StaticResource Close}" />
                </StackPanel>


                <StackPanel 
                    
            Orientation="Horizontal"
            DockPanel.Dock="Right">
                    <!--<cc:ButtonIcon
                    Margin="0"
                        Click="Close_Click"
                        ButtonTemplate="OnlyIcon"
                 Icon="{StaticResource Minus}"
                 />-->
                </StackPanel>

                <StackPanel 
                    HorizontalAlignment="Left"
            Orientation="Horizontal"
            DockPanel.Dock="Right">
                    <Image
           Source="/Resources/Assets/main.png"
           Stretch="Uniform"
           Width="100"
           />
                    <TextBlock Text="Hor Dns"
           FontFamily="{StaticResource Main}"
           FontSize="25"
           VerticalAlignment="Center"
           Foreground="{StaticResource PrimaryTextColor}"/>
                </StackPanel>

            </DockPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <!--Menus-->
                    <ColumnDefinition Width="*"/>
                    <!--Page-->
                    <ColumnDefinition Width="4.5*"/>
                </Grid.ColumnDefinitions>


                <Frame
                    x:Name="Frame"
                    NavigationUIVisibility="Hidden"
                    Source="/Pages/Dashboard.xaml"
                    Grid.Column="1"
                    />
                <!--<Grid Grid.Column="1" Margin="50">
                  
                    <Image
                        Source="/Resources/Assets/bg2.png"
                        >
                        <Image.Effect>
                            <BlurEffect
                                Radius="5"
                                RenderingBias="Quality"
                                />
                        </Image.Effect>
                    </Image>
                    <TextBlock
                        FontFamily="{StaticResource Main}"
                        FontWeight="Bold"
                        Foreground="{StaticResource PrimaryTextColor}"
                        FontSize="24"
                        >
                        Hi
                    </TextBlock>
                 
                </Grid>-->


                <Grid
                    Margin="20 20"
                    >
                    <Grid.Resources>
                        <Style TargetType="cc:ButtonIcon">
                            <Setter Property="Margin" Value="10 20"/>
                            <Setter Property="Height" Value="40"/>

                        </Style>
                    </Grid.Resources>
                    <StackPanel>
                        <cc:ButtonIcon  
                            Content="Dashboard"
                            DistanceBetwewn="20"
                            Click="Dashboard_Click"
                            Icon="{StaticResource Home}"
                            />
                        <cc:ButtonIcon 
                            Content="Settings"
                            DistanceBetwewn="20"
                            Icon="{StaticResource Settings}"
                            />
                        <cc:ButtonIcon 
                             Content="Add"
                             DistanceBetwewn="20"
                             Icon="{StaticResource AddItem}"
                             Click="AddDns_Click"
                             
                             />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Bottom"
                                >
                   
                        <StackPanel Orientation="Horizontal"
                          VerticalAlignment="Bottom"
                          HorizontalAlignment="Center">
                            <StackPanel.Resources>
                                <Style TargetType="Button" BasedOn="{StaticResource ShiningButton}">
                                    <Setter Property="Height" Value="40"/>
                                    <Setter Property="Width" Value="90"/>
                                    <Setter Property="Margin" Value="5 15"/>
                                </Style>
                            </StackPanel.Resources>
                            <Button
                               Background="#B180FF"
                                BorderBrush="#A56EFF"
                               Foreground="{StaticResource SecondTextColor}"
                               Content="Donate"
                               />

                            <Button
                                 Foreground="#FF9C9C"
                                 BorderBrush="#FF9C9C"
                                 Background="#F7C6E3"
                                 Content="Github"
                                />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>

        </Grid>
    </Border>
</Window>
